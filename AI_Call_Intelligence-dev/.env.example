# ── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini

# ── Speech-to-text ──────────────────────────────────────────────────────────
STT_BACKEND=whisper          # whisper | openai_diarize
WHISPER_MODEL_SIZE=small     # tiny | base | small | medium | large

# ── FFmpeg (set full path if ffmpeg is not on system PATH) ───────────────────
# Windows example:
# FFMPEG_PATH=C:\Users\You\AppData\Local\...\ffmpeg.exe
# FFPROBE_PATH=C:\Users\You\AppData\Local\...\ffprobe.exe
# Linux/Mac (if installed via package manager, leave unset — it will be found on PATH)
FFMPEG_PATH=
FFPROBE_PATH=

# ── Speaker diarization (optional) ──────────────────────────────────────────
ENABLE_DIARIZATION=false
DIARIZATION_HF_TOKEN=hf_...

# ── Pipeline ────────────────────────────────────────────────────────────────
PIPELINE_RESUME=false        # true = reuse on-disk artifacts (skip completed stages)

# ── Data paths (defaults work for local dev; override for Docker/Railway) ────
# DATA_DIR=/tmp/app_data
# UPLOAD_DIR=/tmp/app_data/uploads

# ── Server ──────────────────────────────────────────────────────────────────
PORT=8000

# ── Google Calendar ──────────────────────────────────────────────────────────
ENABLE_GOOGLE_CALENDAR=true
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_TOKEN_FILE=google_token.json
# Bot browser login (used by meeting_bot.py to sign in to Google Meet)
GOOGLE_ACCOUNT_EMAIL=you@gmail.com
GOOGLE_ACCOUNT_PASSWORD=your_password

# ── Microsoft Outlook / Teams ────────────────────────────────────────────────
ENABLE_OUTLOOK_CALENDAR=false
MICROSOFT_CLIENT_ID=
MICROSOFT_TENANT_ID=common

# ── Meeting bot behaviour ────────────────────────────────────────────────────
BOT_NAME=Clario
JOIN_EARLY_SECONDS=120
CALENDAR_POLL_INTERVAL=5
BOT_POLL_INTERVAL_SEC=10
BOT_GRACE_SECONDS=30
